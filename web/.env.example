# OpenRoute2 — variables de entorno (template)
# Copia este archivo a `.env` y ajusta los valores según tu entorno.
# NUNCA subas el archivo `.env` real al repositorio.

# ─── Base de datos ──────────────────────────────────────────
# SQLite local. En producción usa una DB externa (Postgres recomendado).
DATABASE_URL="file:./dev.db"

# ─── Autenticación ──────────────────────────────────────────
# Secreto para firmar las cookies JWT de sesión.
# Genera uno aleatorio en producción, p. ej. con: openssl rand -base64 32
JWT_SECRET="cambia-esto-por-un-secreto-aleatorio-en-produccion"

# ─── Ollama (LLM local) ─────────────────────────────────────
# Endpoint del servicio Ollama. Por defecto, instalación local.
OLLAMA_BASE_URL="http://localhost:11434"
# Modelo a usar para el chatbot. Soporta tool calling nativo.
OLLAMA_MODEL="llama3.1:8b"

# ─── OSRM (routing y optimización TSP) ──────────────────────
# Servidor público gratuito. Para uso intensivo, auto-hospedar.
# Docs: https://project-osrm.org/
OSRM_BASE_URL="https://router.project-osrm.org"

# ─── Nominatim (geocoding) ──────────────────────────────────
# Servicio público de OpenStreetMap. Límite: 1 req/segundo.
# Para producción, considerar Photon o auto-hospedar Nominatim.
NOMINATIM_BASE_URL="https://nominatim.openstreetmap.org"

# ─── Depósito / centro logístico ────────────────────────────
# Coordenadas del depósito desde el que parten las rutas.
# Por defecto: Avenida Aguilera, Alicante (centro logístico ficticio).
DEPOT_LAT="38.3460"
DEPOT_LNG="-0.4907"
